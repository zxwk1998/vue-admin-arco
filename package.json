    "echarts": "^6.1.0",
    "install": "^0.13.0",
    "lodash": "^4.18.1",
    "mitt": "^3.0.1",
    "mockjs": "^1.1.0",
    "nprogress": "^0.2.0",
    "pinia": "^3.0.4",
    "pnpm": "^11.8.0",
    "query-string": "^9.4.0",
    "sortablejs": "^1.15.7",
    "typescript": "^6.0.3",
    "vue": "^3.5.38",
    "vue-echarts": "^8.0.1",
