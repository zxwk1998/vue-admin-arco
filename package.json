    "rollup": "^4.62.0",
    "rollup-plugin-visualizer": "^7.0.1",
    "stylelint": "^17.13.0",
    "stylelint-config-prettier": "^9.0.5",
    "stylelint-config-rational-order": "^0.1.2",
    "stylelint-config-recommended-vue": "^1.6.1",
    "stylelint-config-standard": "^40.0.0",
